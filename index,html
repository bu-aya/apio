                if (!bulkInputText.trim()) {
                    triggerAlert('Silakan paste data nilai terlebih dahulu!', 'error');
                    return;
                }
                const lines = bulkInputText.trim().split('\n');
                const updatedGrades = { ...grades };
                let importedCount = 0;

                lines.forEach(line => {
                    // Expected format: NIS/NISN\tScore1\tScore2\tScore3...
                    // Or simple comma-separated
                    const parts = line.replace(/,/g, '\t').split('\t');
                    if (parts.length >= 2) {
                        const identifier = parts[0].trim();
                        const score = parseFloat(parts[1].trim());

                        // Match student
                        const matched = students.find(s => s.nis === identifier || s.nisn === identifier || s.name.toLowerCase() === identifier.toLowerCase());
                        if (matched) {
                            const key = `${bulkInputYear}-Ganjil`; // Defaulting to Ganjil or dynamic
                            if (!updatedGrades[matched.id]) updatedGrades[matched.id] = {};
                            if (!updatedGrades[matched.id][key]) updatedGrades[matched.id][key] = {};
                            
                            updatedGrades[matched.id][key][bulkInputSubject] = score;
                            importedCount++;
